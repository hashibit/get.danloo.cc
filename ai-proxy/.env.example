# AI Proxy Service Environment Variables

# Service Configuration
SERVER_PORT=8001

# AI Provider URL
AI_PROVIDER_URL=http://localhost:8002

# OpenAI 兼容接口 (当前使用 Cerebras)
OPENAI_URL=https://api.cerebras.ai/v1
OPENAI_TOKEN=YOUR_OPENAI_TOKEN
OPENAI_MODEL=zai-glm-4.6
OPENAI_TRAFFIC_RATIO=100
OPENAI_REQUESTS_QUOTA_PER_MINUTE=1000

# Anthropic Configuration
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# S3/OSS Configuration
S3_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
S3_EXTERNAL_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
S3_ACCESS_KEY=YOUR_S3_ACCESS_KEY
S3_SECRET_KEY=YOUR_S3_SECRET_KEY

S3_BUCKET=danloo-uploads
S3_RESULTS_BUCKET=danloo-results
S3_REGION=cn-beijing