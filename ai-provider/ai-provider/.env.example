# =============================================================================
# AI Provider Configuration
# =============================================================================

# Server Configuration
SERVER_PORT=8002

# OpenAI Configuration
OPENAI_URL=https://api.openai.com/v1/chat/completions
OPENAI_TOKEN=your_openai_token_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRAFFIC_RATIO=100
OPENAI_REQUESTS_QUOTA_PER_MINUTE=1000
OPENAI_TOKENS_QUOTA_PER_MINUTE=1000000

# Anthropic Claude Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_TRAFFIC_RATIO=0
ANTHROPIC_REQUESTS_QUOTA_PER_MINUTE=1000
ANTHROPIC_TOKENS_QUOTA_PER_MINUTE=1000000

# AWS Bedrock Configuration (for multimodal content)
AWS_BEDROCK_REGION=us-east-1
AWS_BEDROCK_NOVA_PRO_MODEL_ID=amazon.nova-pro-v1:0
AWS_BEDROCK_NOVA_LITE_MODEL_ID=amazon.nova-lite-v1:0
AWS_BEDROCK_CREDENTIALS=aws-credentials.json

# FFmpeg Configuration (for video processing)
FFMPEG_SAMPLE_FRAMES=10
FFMPEG_SLICE_VIDEO_DURATION=120
FFMPEG_MAX_VIDEO_SIZE=100

# Retry Configuration
RETRY_MAX_ATTEMPTS=1
RETRY_WAIT_MULTIPLIER=1000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=false
LOG_FILE_PATH=logs/app.log
LOG_MAX_FILE_SIZE=104857600
LOG_BACKUP_COUNT=5

# Thread Pool Configuration
TEXT_EXECUTOR_WORKERS=64
MULTIMODAL_EXECUTOR_WORKERS=32
TEXT_MAX_QUEUE_SIZE=128
MULTIMODAL_MAX_QUEUE_SIZE=64