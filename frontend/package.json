{
  "name": "danloo-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:en": "DEFAULT_LOCALE=en next dev",
    "dev:zh": "DEFAULT_LOCALE=zh next dev",
    "dev:frontend": "next dev",
    "dev:backend": "cd ../backend && uv run uvicorn main:app --reload",
    "dev:ai-provider": "cd ../ai-provider && uv run uvicorn ai_provider.main:app --reload --port 8002",
    "dev:process": "cd ../process && uv run uvicorn process.main:app --reload --port 8001",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:ai-provider\" \"npm run dev:process\" \"npm run dev:frontend\"",
    "build": "next build",
    "build:en": "DEFAULT_LOCALE=en next build",
    "build:zh": "DEFAULT_LOCALE=zh next build",
    "start": "npx next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@types/mermaid": "^9.1.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "i18next": "^25.4.0",
    "mermaid": "^11.12.0",
    "next": "13.4.19",
    "next-i18next": "^15.4.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "^15.7.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-mermaid": "^3.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.1.2",
    "@testing-library/react": "14.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "20.5.6",
    "@types/react": "18.2.21",
    "@types/react-dom": "18.2.7",
    "autoprefixer": "10.4.15",
    "concurrently": "^9.2.1",
    "eslint": "8.48.0",
    "eslint-config-next": "13.4.19",
    "jest": "29.6.2",
    "jest-environment-jsdom": "^30.0.5",
    "playwright": "^1.55.0",
    "postcss": "8.4.28",
    "tailwindcss": "3.3.3",
    "testing-library": "0.0.2",
    "ts-jest": "29.1.1",
    "typescript": "5.2.2"
  }
}
